{
  "name": "www.kymasoft.com",
  "version": "1.0.0",
  "private": true,
  "description": "Tooling for www.kymasoft.com",
  "scripts": {
    "serve": "hugo server --bind 0.0.0.0 --port ${PREVIEW_PORT:-1315} --liveReloadPort ${PREVIEW_PORT:-1315} --baseURL ${PREVIEW_BASE_URL:-http://localhost:1315} --disableFastRender --cleanDestinationDir",
    "build": "hugo --gc --minify --cleanDestinationDir",
    "test": "node scripts/assert-built-content.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#docs\" \"#themes\" \"#node_modules\"",
    "lint:toml": "taplo check",
    "lint": "npm run format:check && npm run lint:md && npm run lint:toml",
    "verify": "npm run lint && npm run build && npm run test",
    "ci": "npm run verify"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@taplo/cli": "^0.7.0",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.6.2"
  }
}
