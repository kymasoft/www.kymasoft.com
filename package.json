{
  "name": "www.kymasoft.com",
  "version": "1.0.0",
  "private": true,
  "description": "Tooling for www.kymasoft.com",
  "scripts": {
    "serve": "hugo server --bind 0.0.0.0 --baseURL http://localhost:1313 --destination docs --disableFastRender",
    "build": "hugo --gc --minify --destination docs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#docs\" \"#themes\" \"#node_modules\"",
    "lint:toml": "taplo check",
    "lint": "npm run format:check && npm run lint:md && npm run lint:toml",
    "ci": "npm run lint && npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@taplo/cli": "^0.7.0",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.6.2"
  }
}
